{
  "name": "tytec-pricing-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone desktop pricing engine for customer invoice preparation.",
  "author": "Tytec",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run check:lines && tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "electron": "electron .",
    "desktop": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win nsis portable",
    "check:lines": "node scripts/check-line-count.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "antd": "^6.3.7",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-pdf": "^10.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "typescript": "^5.5.4",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.tytec.pricingengine",
    "productName": "Tytec Pricing Engine",
    "asar": true,
    "icon": "build/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/icon.ico",
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
